{
  "name": "gms-catalog",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "dev:api": "pnpm --filter @gms-catalog/api dev",
    "dev:web": "pnpm --filter @gms-catalog/web dev",
    "db:seed": "pnpm --filter @gms-catalog/api seed",
    "db:migrate": "pnpm --filter @gms-catalog/api db:migrate",
    "db:generate": "pnpm --filter @gms-catalog/api db:generate",
    "db:studio": "pnpm --filter @gms-catalog/api db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^7.0.2"
  }
}
